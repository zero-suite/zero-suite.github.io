#!/usr/bin/env bash
# Zero Suite — CLI Installer
# Usage: curl -fsSL https://raw.githubusercontent.com/zero-suite/zero-suite/main/scripts/install.sh | bash
set -euo pipefail

REPO="zero-suite/zero-suite"
INSTALL_DIR="${INSTALL_DIR:-/usr/local/bin}"
BINARIES=(vz vault-zero-mcp deploy-zero-mcp spend-zero-mcp log-zero-mcp)

# ── Colours ──────────────────────────────────────────────────────

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}→${RESET} $*"; }
success() { echo -e "${GREEN}✓${RESET} $*"; }
warn()    { echo -e "${YELLOW}!${RESET} $*"; }
error()   { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── Detect OS & Arch ─────────────────────────────────────────────

detect_target() {
    local os arch
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch=$(uname -m)

    case "$arch" in
        x86_64|amd64)  arch="x86_64" ;;
        arm64|aarch64) arch="aarch64" ;;
        *) error "Unsupported architecture: $arch" ;;
    esac

    case "$os" in
        linux)  echo "${arch}-unknown-linux-gnu" ;;
        darwin) echo "${arch}-apple-darwin" ;;
        *) error "Unsupported OS: $os (Windows users: use the PowerShell installer)" ;;
    esac
}

# ── Get latest release version ───────────────────────────────────

get_latest_version() {
    local version
    version=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep '"tag_name"' | sed 's/.*"tag_name": "\(.*\)".*/\1/')
    if [ -z "$version" ]; then
        error "Could not determine latest version. Check your internet connection."
    fi
    echo "$version"
}

# ── Download and install ─────────────────────────────────────────

install_from_release() {
    local version target archive_name archive_url tmpdir

    version=$(get_latest_version)
    target=$(detect_target)
    archive_name="zero-suite-${version}-${target}.tar.gz"
    archive_url="https://github.com/${REPO}/releases/download/${version}/${archive_name}"

    info "Installing Zero Suite ${BOLD}${version}${RESET} for ${target}..."

    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT

    info "Downloading ${archive_name}..."
    if ! curl -fsSL "$archive_url" -o "${tmpdir}/${archive_name}"; then
        warn "Prebuilt binary not found for ${target}. Falling back to cargo install..."
        install_from_cargo
        return
    fi

    tar -xzf "${tmpdir}/${archive_name}" -C "$tmpdir"

    # Install each binary
    local installed=()
    for bin in "${BINARIES[@]}"; do
        if [ -f "${tmpdir}/${bin}" ]; then
            install -m 755 "${tmpdir}/${bin}" "${INSTALL_DIR}/${bin}"
            installed+=("$bin")
        fi
    done

    if [ ${#installed[@]} -eq 0 ]; then
        warn "No binaries found in release archive. Falling back to cargo install..."
        install_from_cargo
        return
    fi

    success "Installed: ${installed[*]}"
}

install_from_cargo() {
    if ! command -v cargo &>/dev/null; then
        error "cargo not found. Install Rust: https://rustup.rs"
    fi

    info "Building from source with cargo (this takes ~5 minutes)..."
    cargo install --git "https://github.com/${REPO}" \
        vault-zero-cli vault-zero-mcp deploy-zero-mcp spend-zero-mcp log-zero-mcp \
        --locked 2>&1

    # Cargo installs to ~/.cargo/bin — check if it's in PATH
    if [[ ":$PATH:" != *":$HOME/.cargo/bin:"* ]]; then
        warn "Add ~/.cargo/bin to your PATH:"
        warn '  export PATH="$HOME/.cargo/bin:$PATH"'
    fi
}

# ── Verify install dir is writable ───────────────────────────────

ensure_install_dir() {
    if [ ! -d "$INSTALL_DIR" ]; then
        mkdir -p "$INSTALL_DIR" 2>/dev/null || {
            warn "Cannot create ${INSTALL_DIR}. Trying with sudo..."
            sudo mkdir -p "$INSTALL_DIR"
        }
    fi

    if [ ! -w "$INSTALL_DIR" ]; then
        warn "${INSTALL_DIR} is not writable. Re-running with sudo..."
        exec sudo bash "$0" "$@"
    fi
}

# ── Post-install verification ────────────────────────────────────

verify_install() {
    if command -v vz &>/dev/null; then
        local version
        version=$(vz --version 2>/dev/null | head -1 || echo "unknown")
        success "vz ${version} is ready"
    else
        warn "vz not found in PATH. You may need to add ${INSTALL_DIR} to PATH."
    fi
}

# ── Main ─────────────────────────────────────────────────────────

main() {
    echo ""
    echo -e "${BOLD}Zero Suite — Installer${RESET}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    ensure_install_dir
    install_from_release
    verify_install

    echo ""
    echo -e "${BOLD}Next steps:${RESET}"
    echo "  1. Initialize your vault:  ${CYAN}vz init${RESET}"
    echo "  2. Add a secret:           ${CYAN}vz add ANTHROPIC_API_KEY sk-ant-...${RESET}"
    echo "  3. Generate .env files:    ${CYAN}vz env /path/to/project${RESET}"
    echo "  4. AI agent integration:   Add vault-zero-mcp to your MCP config"
    echo ""
    echo -e "  Docs: ${CYAN}https://zerosuite.dev/docs${RESET}"
    echo ""
}

main "$@"
